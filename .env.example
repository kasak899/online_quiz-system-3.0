# ─── EduQuiz Arena — Environment Variables ───────────────────
# Copy this file to .env and fill in your values

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/eduquiz
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/eduquiz

# JWT Secret Key (change this to a long random string in production!)
JWT_SECRET=eduquiz_super_secret_change_this_in_production_xyz123

# Server Port
PORT=5000

# Frontend URL (for CORS in production)
CLIENT_URL=http://localhost:3000